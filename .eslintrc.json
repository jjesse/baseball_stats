{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "ignorePatterns": [
    "node_modules/"
  ],
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": {
        "node": true
      }
    }
  ]
}
